# Database (Neon PostgreSQL - https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Authentication
JWT_SECRET="your-very-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION_DAYS=10000

# AI Providers
# Default provider: "openai" or "gemini"
AI_PROVIDER="openai"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL_HIGH="o3-mini-2025-01-31"
OPENAI_MODEL_MEDIUM="o3-mini-2025-01-31"
OPENAI_MODEL_LOW="gpt-4o"

# Google Gemini
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL_HIGH="gemini-2.5-pro-preview-05-06"
GEMINI_MODEL_MEDIUM="gemini-2.0-pro-exp"
GEMINI_MODEL_LOW="gemini-2.0-flash"

# App
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="State Sandbox"

# Credits
CREDITS_DEFAULT=10
CREDITS_NEW_STATE_COST=1
CREDITS_NEXT_YEAR_COST=1

# Email (optional - Postmark)
POSTMARK_API_KEY="your-postmark-key"
EMAIL_FROM="noreply@yourdomain.com"

# Stripe (optional - for credits purchase)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
